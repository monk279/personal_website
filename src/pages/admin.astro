                <button type="button" data-mod-kind="${kind}" data-mod-id="${row.id}" data-mod-status="approved">Approve</button>
                <button class="secondary" type="button" data-mod-kind="${kind}" data-mod-id="${row.id}" data-mod-status="hidden">Hide</button>
                <button class="secondary danger" type="button" data-mod-kind="${kind}" data-mod-id="${row.id}" data-mod-status="spam">Spam</button>

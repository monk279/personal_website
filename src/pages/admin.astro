  const portfolioPieColors = ["#2563eb", "#059669", "#d97706", "#7c3aed", "#dc2626", "#0891b2", "#4f46e5", "#65a30d"];

  function positionMetrics(row: any) {
    const quantity = Number(row.quantity);
    const costBasis = Number(row.costBasisCents) / 100;
    const avgCost = quantity > 0 && Number.isFinite(costBasis) ? costBasis / quantity : 0;
    const quotePrice = Number(row.quote?.price);
    const fxRate = Number(row.quote?.fxRateToBase || 1);
    const hasQuote = Boolean(row.quote) && Number.isFinite(quotePrice) && quotePrice > 0 && Number.isFinite(fxRate) && fxRate > 0;
    const marketValue = hasQuote && Number.isFinite(quantity) ? quantity * quotePrice * fxRate : 0;
    const pnl = hasQuote ? marketValue - costBasis : 0;
    const returnPercent = hasQuote && costBasis > 0 ? (pnl / costBasis) * 100 : 0;
    return {
      quantity,
      costBasis,
      avgCost,
      quotePrice,
      hasQuote,
      marketValue,
      pnl,
      returnPercent,
      currency: row.currency || row.quote?.currency || "USD",
      quoteStatus: row.quote ? `${row.quote.status} · ${row.quote.asOf}` : "No quote"
    };
  }

  function piePath(startPercent: number, endPercent: number) {
    const startAngle = startPercent * 3.6 - 90;
    const endAngle = endPercent * 3.6 - 90;
    const point = (angle: number) => {
      const radians = (angle * Math.PI) / 180;
      return {
        x: 50 + 46 * Math.cos(radians),
        y: 50 + 46 * Math.sin(radians)
      };
    };
    const start = point(startAngle);
    const end = point(endAngle);
    const largeArc = endPercent - startPercent > 50 ? 1 : 0;
    return `M 50 50 L ${start.x.toFixed(3)} ${start.y.toFixed(3)} A 46 46 0 ${largeArc} 1 ${end.x.toFixed(3)} ${end.y.toFixed(3)} Z`;
  }

  function renderAdminPie(allocations: { label: string; value: number; weightPercent: number }[]) {
    if (!allocations.length) {
      return `
        <div class="admin-pie-empty" aria-hidden="true">No priced holdings</div>
        <p class="studio-muted">Refresh quotes to build the allocation chart.</p>
      `;
    }
    let cursor = 0;
    const slices = allocations.map((item, index) => {
      const start = cursor;
      cursor += item.weightPercent;
      if (item.weightPercent >= 99.99) {
        return `<circle cx="50" cy="50" r="46" fill="${portfolioPieColors[index % portfolioPieColors.length]}"></circle>`;
      }
      return `<path d="${piePath(start, cursor)}" fill="${portfolioPieColors[index % portfolioPieColors.length]}"></path>`;
    }).join("");
    const legend = allocations.map((item, index) => `
      <li>
        <span class="portfolio-pie-swatch" style="--slice-color:${portfolioPieColors[index % portfolioPieColors.length]}"></span>
        <span>${escapeHtml(item.label)}</span>
        <strong>${item.weightPercent.toFixed(1)}%</strong>
      </li>
    `).join("");
    return `
      <svg class="admin-portfolio-pie" viewBox="0 0 100 100" role="img" aria-label="Portfolio allocation by asset class">
        ${slices}
        <circle cx="50" cy="50" r="46" fill="none" stroke="#e2e8f0" stroke-width="1.5"></circle>
      </svg>
      <ul class="admin-pie-legend">${legend}</ul>
    `;
  }

  function selectedOption(value: string, current: unknown) {
    return value === String(current ?? "") ? " selected" : "";
  }

  async function loadPortfolio() {
    const data = await api("/api/admin/portfolio/positions");
    portfolioPositions = data.positions || [];
    const target = document.querySelector("[data-portfolio-admin]");
    if (!target) return;
    if (!portfolioPositions.length) {
      target.innerHTML = "<p class='studio-muted'>No positions yet.</p>";
      return;
    }
    const rows = portfolioPositions.map((row) => ({ row, metrics: positionMetrics(row) }));
    const activeRows = rows.filter(({ row, metrics }) => row.status === "active" && metrics.hasQuote);
    const totalMarketValue = activeRows.reduce((sum, item) => sum + item.metrics.marketValue, 0);
    const totalCostBasis = rows
      .filter(({ row }) => row.status === "active")
      .reduce((sum, item) => sum + item.metrics.costBasis, 0);
    const totalPnl = totalMarketValue - totalCostBasis;
    const totalReturnPercent = totalCostBasis > 0 ? (totalPnl / totalCostBasis) * 100 : 0;
    const allocationMap = new Map<string, number>();
    for (const { row, metrics } of activeRows) {
      allocationMap.set(row.assetClass, (allocationMap.get(row.assetClass) ?? 0) + metrics.marketValue);
    }
    const allocations = [...allocationMap.entries()]
      .map(([label, value]) => ({ label, value, weightPercent: totalMarketValue > 0 ? (value / totalMarketValue) * 100 : 0 }))
      .sort((a, b) => b.value - a.value);
    target.innerHTML = `
      <section class="portfolio-admin-dashboard">
        <article class="portfolio-admin-card portfolio-admin-chart">
          <div>
            <p class="studio-kicker">Allocation</p>
            <h3>By asset class</h3>
          </div>
          ${renderAdminPie(allocations)}
        </article>
        <article class="portfolio-admin-card">
          <span class="studio-muted">Market value</span>
          <strong>${formatMoney(totalMarketValue, "USD")}</strong>
        </article>
        <article class="portfolio-admin-card">
          <span class="studio-muted">Cost basis</span>
          <strong>${formatMoney(totalCostBasis, "USD")}</strong>
        </article>
        <article class="portfolio-admin-card">
          <span class="studio-muted">Unrealized P/L</span>
          <strong class="${totalPnl >= 0 ? "portfolio-pnl-positive" : "portfolio-pnl-negative"}">${formatMoney(totalPnl, "USD")} · ${formatPercent(totalReturnPercent)}</strong>
        </article>
      </section>
      <table class="studio-table portfolio-sheet-table">
        <thead><tr><th>Ticker</th><th>Name</th><th>Class</th><th>Region</th><th>Qty</th><th>Avg cost</th><th>Latest</th><th>Value</th><th>P/L</th><th>Status</th><th></th></tr></thead>
        <tbody>
          ${rows.map(({ row, metrics }: any) => `
            <tr data-position-row="${row.id}">
              <td><input data-inline-field="ticker" value="${escapeHtml(row.ticker)}" aria-label="Ticker" /></td>
              <td><input data-inline-field="name" value="${escapeHtml(row.name)}" aria-label="Name" /></td>
              <td><input data-inline-field="assetClass" value="${escapeHtml(row.assetClass)}" aria-label="Asset class" /></td>
              <td><input data-inline-field="region" value="${escapeHtml(row.region)}" aria-label="Region" /></td>
              <td><input data-inline-field="quantity" type="number" min="0" step="0.0001" value="${escapeHtml(row.quantity)}" aria-label="Quantity" /></td>
              <td>
                <input data-inline-field="costPrice" type="number" min="0" step="0.0001" value="${escapeHtml(costPriceInputFromPosition(row))}" aria-label="Average cost" />
                <span class="studio-muted">cost ${formatMoney(metrics.costBasis, row.currency)}</span>
              </td>
              <td>${metrics.hasQuote ? `${formatMoney(metrics.quotePrice, row.quote?.currency || row.currency)}<br><span class="studio-muted">${escapeHtml(metrics.quoteStatus)}</span>` : "<span class='studio-muted'>Refresh quotes</span>"}</td>
              <td>${metrics.hasQuote ? formatMoney(metrics.marketValue, "USD") : "—"}</td>
              <td>${metrics.hasQuote ? `<span class="${metrics.pnl >= 0 ? "portfolio-pnl-positive" : "portfolio-pnl-negative"}">${formatMoney(metrics.pnl, "USD")}<br>${formatPercent(metrics.returnPercent)}</span>` : "—"}</td>
              <td>
                <select data-inline-field="status" aria-label="Status">
                  <option value="active"${selectedOption("active", row.status)}>active</option>
                  <option value="watchlist"${selectedOption("watchlist", row.status)}>watchlist</option>
                  <option value="closed"${selectedOption("closed", row.status)}>closed</option>
                </select>
              </td>
              <td>
                <button type="button" data-save-position-row="${row.id}">Save</button>
                <button type="button" data-edit-position="${row.id}">Edit</button>
                <button class="secondary danger" type="button" data-delete-position="${row.id}">Delete</button>
              </td>
            </tr>
          `).join("")}
        </tbody>
      </table>
    `;
  }

  function fillPositionForm(position?: any) {
    const form = document.querySelector("[data-position-form]") as HTMLFormElement | null;
    if (!form) return;
    form.reset();
      const fields = {
        id: position?.id ?? "",
      assetId: position?.assetId ?? "",
      provider: "alpha_vantage",
      exchange: "",
      ticker: position?.ticker ?? "",
      name: position?.name ?? "",
      assetClass: position?.assetClass ?? "",
      region: position?.region ?? "",
      currency: position?.currency ?? "USD",
      asOf: position?.asOf ?? todayDateInputValue(),
      quantity: position?.quantity ?? "",
      costBasisCents: position?.costBasisCents ?? "",
      costPrice: costPriceInputFromPosition(position),
      aliases: position?.aliases?.join?.(", ") ?? "",
      status: position?.status ?? "active",
      notes: position?.notes ?? ""
    };
    for (const [key, value] of Object.entries(fields)) {
      const field = form.elements.namedItem(key) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | null;
      if (field) field.value = String(value);
    }
    const submit = document.querySelector("[data-position-submit]");
    const cancel = document.querySelector("[data-position-cancel]") as HTMLElement | null;
    if (submit) submit.textContent = position?.id ? "Save position" : "Add position";
    if (cancel) cancel.hidden = !position?.id;
    updateCostBasisPreview();
  }

  function renderMarketResults(assets: any[], query = "") {
    const target = document.querySelector("[data-market-results]") as HTMLElement | null;
    if (!target) return;
    const manual = query.trim()
      ? [{
        id: "",
        provider: "manual",
        symbol: query.trim().toUpperCase().replace(/[^A-Z0-9.-]/g, "").slice(0, 24) || query.trim(),
        name: query.trim(),
        assetType: "Equity",
        region: "Global",
        currency: "USD",
        exchange: "Manual",
        aliases: [query.trim()],
        source: "manual"
      }]
      : [];
    const rows = [...assets, ...manual];
    if (!rows.length) {
      target.hidden = true;
      target.innerHTML = "";
      marketSearchInput?.setAttribute("aria-expanded", "false");
      return;
    }
    target.hidden = false;
    marketSearchInput?.setAttribute("aria-expanded", "true");
    target.innerHTML = rows.map((asset, index) => `
      <article class="studio-list-item compact" role="option" aria-selected="${index === 0 ? "true" : "false"}">
        <div>
          <strong>${escapeHtml(asset.symbol)}</strong> ${escapeHtml(asset.name)}
          <div class="studio-meta"><span>${escapeHtml(asset.assetType)}</span><span>${escapeHtml(asset.region || "")}</span><span>${escapeHtml(asset.currency)}</span><span>${escapeHtml(asset.source || "provider")}</span></div>
        </div>
        <button type="button"
          data-select-asset="${escapeHtml(asset.id)}"
          data-asset-symbol="${escapeHtml(asset.symbol)}"
          data-asset-name="${escapeHtml(asset.name)}"
          data-asset-type="${escapeHtml(asset.assetType)}"
          data-asset-region="${escapeHtml(asset.region || "")}"
          data-asset-currency="${escapeHtml(asset.currency)}"
          data-asset-provider="${escapeHtml(asset.provider)}"
          data-asset-aliases="${escapeHtml((asset.aliases || []).join(", "))}"
          data-asset-exchange="${escapeHtml(asset.exchange || "")}">${asset.source === "manual" ? "Use manual" : "Use"}</button>
      </article>
    `).join("");
  }

  async function searchMarketAssets(query: string) {
    if (query.trim().length < 1) {
      renderMarketResults([]);
      return;
    }
    if (marketStatus) marketStatus.textContent = "Searching provider and cached assets...";
    const data = await api(`/api/admin/market/search?q=${encodeURIComponent(query.trim())}&lang=en`);
    if (marketStatus) {
      marketStatus.textContent = data.providerStatus?.ok
        ? "Provider results and cached fuzzy matches loaded."
        : `${data.providerStatus?.message || "Provider unavailable."} Showing cached/manual fallback.`;
    }
    renderMarketResults(data.assets || [], query);
  }

  async function loadProfile() {
    const data = await api("/api/admin/profile");
    const form = document.querySelector("[data-profile-form]") as HTMLFormElement | null;
    if (!form || !data.profile) return;
    for (const [key, value] of Object.entries(data.profile)) {
      const field = form.elements.namedItem(key) as HTMLInputElement | HTMLTextAreaElement | null;
      if (field) field.value = String(value ?? "");
    }
  }

  async function loadMe() {
    try {
      const data = await api("/api/admin/me");
      if (!data.authenticated || !data.admin) throw new Error("Not logged in");
      csrfToken = data.csrfToken;
      setLoggedIn(data.admin);
      updatePendingBadges(data.pending);
      setStatus("Logged in.");
      await Promise.all([loadContentPosts(), loadComments(), loadPortfolio(), loadProfile()]);
    } catch (error) {
      retryMeAfterApiOnline = error instanceof AdminApiError && error.code === "API_UNAVAILABLE";
      if (retryMeAfterApiOnline) {
        setAdminState("offline");
        setLoginDisabled(true);
        setStatus(apiCheckingMessage);
      } else {
        setLoggedOut("Log in to manage the site.");
      }
    }
  }

  function openLinkDialog() {
    const textInput = linkDialogForm?.elements.namedItem("text") as HTMLInputElement | null;
    const urlInput = linkDialogForm?.elements.namedItem("url") as HTMLInputElement | null;
    if (textInput) textInput.value = selectedEditorText() || "link text";
    if (urlInput) urlInput.value = "";
    linkDialog?.showModal();
  }


  const positionForm = document.querySelector("[data-position-form]") as HTMLFormElement | null;
  positionForm?.addEventListener("input", updateCostBasisPreview);
  positionForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const form = event.currentTarget as HTMLFormElement;
    const raw = Object.fromEntries(new FormData(form).entries()) as Record<string, any>;
    const { id: rawId, costPrice, ...positionRaw } = raw;
    const id = rawId ? Number(rawId) : null;
    const costBasisCents = costPrice !== undefined && String(costPrice).trim() !== ""
      ? costBasisCentsFromInputs(positionRaw.quantity, costPrice)
      : Number(positionRaw.costBasisCents || 0);
    const body = {
      ...positionRaw,
      assetId: positionRaw.assetId ? Number(positionRaw.assetId) : undefined,
      asOf: positionRaw.asOf || todayDateInputValue(),
      quantity: Number(positionRaw.quantity),
      costBasisCents
    };
    await api(id ? `/api/admin/portfolio/positions/${id}` : "/api/admin/portfolio/positions", {
      method: id ? "PATCH" : "POST",
      body: JSON.stringify(body)
    });
    fillPositionForm();
    await loadPortfolio();
    setStatus(id ? "Position saved." : "Position added.");
  });

  document.querySelector("[data-profile-form]")?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const form = event.currentTarget as HTMLFormElement;
    await api("/api/admin/profile", { method: "PATCH", body: JSON.stringify(Object.fromEntries(new FormData(form).entries())) });
    setStatus("Profile saved.");
  });

  setupEditor();
  setEditorMode("edit");
  fillPositionForm();
  startOwnerStatusChecks();
  loadMe();
</script>

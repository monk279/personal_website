  function slugify(value: string) {
    return value
      .toLowerCase()
      .normalize("NFKD")
      .replace(/[^\w\s-]/g, "")
      .trim()
      .replace(/[\s_]+/g, "-")
      .replace(/-+/g, "-")
      .replace(/^-|-$/g, "") || "untitled";
  }

  function setupEditor() {
    if (!editorHost || docsEditor) return;
    docsEditor = createDocsEditor({
      element: editorHost,
      initialMarkdown: markdownSource?.value ?? "",
      placeholder: "Start writing. Type / for blocks.",
      onUpdate: (markdown) => {
        syncMarkdownSource(markdown);
        if (!suppressEditorDirty) {
          setSaveState("Unsaved changes", "dirty");
          scheduleEditorPreview();
          scheduleDraftAutosave();
        }
      },
      onSelectionUpdate: updateEditorChrome,
      onRequestLink: openLinkDialog,
      onRequestImage: () => (document.querySelector("[data-asset-upload]") as HTMLInputElement | null)?.click()
    });
    editorHost.addEventListener("keydown", (event) => {
      if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === "s") {
        event.preventDefault();
        contentForm?.requestSubmit(contentForm.querySelector("[data-save-status='draft']") as HTMLButtonElement | null);
      }
    });
    editorHost.addEventListener("mouseup", () => window.setTimeout(() => updateEditorChrome(), 0));
    editorHost.addEventListener("keyup", () => updateEditorChrome());
    updateEditorChrome();
  }

  function getEditorMarkdown() {
    setupEditor();
    return docsEditor?.getMarkdown() ?? markdownSource?.value ?? "";
  }

  function syncMarkdownSource(value = getEditorMarkdown()) {
    if (markdownSource) markdownSource.value = value;
  }

  function setEditorMarkdown(value: string) {
    setupEditor();
    suppressEditorDirty = true;
    docsEditor?.setMarkdown(value);
    syncMarkdownSource(value);
    suppressEditorDirty = false;
    setSaveState("Ready", "idle");
    scheduleEditorPreview(0);
    updateEditorChrome();
  }

  function setEditorMode(mode: string) {
    if (editorStage) editorStage.setAttribute("data-mode", mode);
    for (const button of document.querySelectorAll("[data-editor-view]")) {
      button.classList.toggle("active", button.getAttribute("data-editor-view") === mode);
    }
    if (mode !== "edit") scheduleEditorPreview(0);
  }

  function renderClientPreviewFallback(markdown: string) {
    return escapeHtml(markdown)
      .replace(/^### (.*)$/gm, "<h3>$1</h3>")
      .replace(/^## (.*)$/gm, "<h2>$1</h2>")
      .replace(/^# (.*)$/gm, "<h1>$1</h1>")
      .replace(/!\[([^\]]*)\]\((https?:\/\/[^)\s]+|\/[^)\s]+)\)/g, '<img src="$2" alt="$1" />')
      .replace(/\[([^\]]+)\]\((https?:\/\/[^)\s]+|\/[^)\s]+|mailto:[^)\s]+)\)/g, '<a href="$2">$1</a>')
      .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
      .replace(/\*([^*]+)\*/g, "<em>$1</em>")
      .replace(/^&gt; (.*)$/gm, "<blockquote>$1</blockquote>")
      .replace(/```([\s\S]*?)```/g, "<pre><code>$1</code></pre>")
      .replace(/^- (.*)$/gm, "<ul><li>$1</li></ul>")
      .replace(/\n{2,}/g, "</p><p>")
      .replace(/^(?!<h|<p|<blockquote|<img|<ul|<pre)(.+)$/gm, "<p>$1</p>");
  }

  async function renderEditorPreviewNow() {
    if (!editorPreview) return;
    const markdown = getEditorMarkdown();
    if (!markdown.trim()) {
      editorPreview.innerHTML = "<p class='studio-muted'>Preview appears here.</p>";
      return;
    }
    const requestId = ++previewRequestId;
    try {
      const data = await api("/api/admin/content/preview", { method: "POST", body: JSON.stringify({ bodyMarkdown: markdown }) });
      if (requestId === previewRequestId) editorPreview.innerHTML = data.html || "";
    } catch {
      if (requestId === previewRequestId) editorPreview.innerHTML = renderClientPreviewFallback(markdown);
    }
  }

  function scheduleEditorPreview(delay = 250) {
    window.clearTimeout(previewTimer);
    previewTimer = window.setTimeout(() => {
      renderEditorPreviewNow();
    }, delay);
  }

  function replaceEditorSelection(before: string, after = "", placeholder = "") {
    setupEditor();
    docsEditor?.insertMarkdown(`${before}${selectedEditorText() || placeholder}${after}`);
    syncMarkdownSource();
    scheduleEditorPreview();
    updateEditorChrome();
  }

  function selectedEditorText() {
    setupEditor();
    return docsEditor?.getSelectedText() || "";
  }

  function applyDocCommand(command: string) {
    setupEditor();
    docsEditor?.runCommand(command);
    syncMarkdownSource();
    scheduleEditorPreview();
    updateEditorChrome();
  }

  function insertEditorImage(src: string, alt = "") {

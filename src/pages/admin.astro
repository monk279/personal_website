  function publicPostHref(post: any) {
    return post.lang === "zh"
      ? `/zh/blog/${encodeURIComponent(post.slug)}`
      : `/blog/${encodeURIComponent(post.slug)}`;
  }

  function todayDateInputValue() {
    const now = new Date();
    now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
    return now.toISOString().slice(0, 10);
  }

  function formatMoney(value: unknown, currency = "USD") {
    const amount = Number(value);
    if (!Number.isFinite(amount)) return "—";
    try {
      return new Intl.NumberFormat("en-US", {
        style: "currency",
        currency: String(currency || "USD").toUpperCase(),
        maximumFractionDigits: Math.abs(amount) >= 1000 ? 0 : 2
      }).format(amount);
    } catch {
      return `${String(currency || "USD").toUpperCase()} ${amount.toFixed(2)}`;
    }
  }

  function formatPercent(value: unknown) {
    const amount = Number(value);
    if (!Number.isFinite(amount)) return "—";
    return `${amount >= 0 ? "+" : ""}${amount.toFixed(2)}%`;
  }

  function costPriceInputFromPosition(position?: any) {
    const quantity = Number(position?.quantity);
    const cents = Number(position?.costBasisCents);
    if (!Number.isFinite(quantity) || quantity <= 0 || !Number.isFinite(cents) || cents <= 0) return "";
    return (cents / 100 / quantity).toFixed(4).replace(/\.?0+$/, "");
  }

  function costBasisCentsFromInputs(quantity: unknown, costPrice: unknown) {
    const quantityValue = Number(quantity);
    const costPriceValue = Number(costPrice);
    if (!Number.isFinite(quantityValue) || quantityValue <= 0 || !Number.isFinite(costPriceValue) || costPriceValue < 0) return 0;
    return Math.round(quantityValue * costPriceValue * 100);
  }

  function updateCostBasisPreview() {
    const form = document.querySelector("[data-position-form]") as HTMLFormElement | null;
    const target = document.querySelector("[data-cost-basis-preview]");
    if (!form || !target) return;
    const quantity = (form.elements.namedItem("quantity") as HTMLInputElement | null)?.value;
    const costPrice = (form.elements.namedItem("costPrice") as HTMLInputElement | null)?.value;
    const currency = (form.elements.namedItem("currency") as HTMLInputElement | null)?.value || "USD";
    const hiddenCostBasis = form.elements.namedItem("costBasisCents") as HTMLInputElement | null;
    const cents = costBasisCentsFromInputs(quantity, costPrice);
    if (hiddenCostBasis) hiddenCostBasis.value = cents > 0 ? String(cents) : "";
    target.textContent = cents > 0
      ? `Total cost basis: ${formatMoney(cents / 100, currency)}. P/L uses latest quote minus this cost basis.`
      : "Total cost basis will be calculated from quantity and average cost price.";
  }

  function fillContentForm(post?: any) {
    const form = contentForm;
    if (!form) return;
    form.reset();
    const fields = {
      id: post?.id ?? "",
      lang: post?.lang ?? "en",
      status: post?.status ?? "draft",
      title: post?.title ?? "",
      slug: post?.slug ?? "",
      category: post?.category ?? "Notes",
      tags: (post?.tags || []).join(", "),
      publishedAt: post?.publishedAt ? String(post.publishedAt).slice(0, 16) : "",
      description: post?.description ?? "",
      bodyMarkdown: post?.bodyMarkdown ?? ""
    };
    for (const [key, value] of Object.entries(fields)) {
      const field = form.elements.namedItem(key) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | null;
      if (field) field.value = String(value);
    }
    setEditorMarkdown(String(fields.bodyMarkdown));
    const editorTitle = document.querySelector("[data-editor-title]");
    const editorStatus = document.querySelector("[data-editor-status]");
    if (editorTitle) editorTitle.textContent = post?.id ? "Edit post" : "New post";
    if (editorStatus) editorStatus.textContent = post?.status ?? "draft";
    const currentVersion = document.querySelector("[data-current-version]");
    if (currentVersion) currentVersion.textContent = `v${post?.version ?? 1}`;
    const open = document.querySelector("[data-content-open]") as HTMLAnchorElement | null;
    if (open) open.href = post?.slug ? publicPostHref(post) : "/blog";
    post?.id ? loadRevisions(post.id) : renderRevisions([]);
  }

  function readContentForm(form: HTMLFormElement) {
    syncMarkdownSource();
    const raw = Object.fromEntries(new FormData(form).entries()) as Record<string, string>;
    return {
      id: raw.id ? Number(raw.id) : null,
      lang: raw.lang,
      status: raw.status,
      title: raw.title,
      slug: raw.slug,
      category: raw.category || "Notes",
      tags: (raw.tags || "").split(",").map((tag) => tag.trim()).filter(Boolean),
      publishedAt: raw.publishedAt ? new Date(raw.publishedAt).toISOString() : null,
      description: raw.description,
      bodyMarkdown: raw.bodyMarkdown || getEditorMarkdown()
    };
  }

  function scheduleDraftAutosave() {
    if (!contentForm || suppressEditorDirty) return;
    const id = (contentForm.elements.namedItem("id") as HTMLInputElement | null)?.value;
    const status = (contentForm.elements.namedItem("status") as HTMLSelectElement | null)?.value;
    if (!id || status !== "draft") return;
    window.clearTimeout(draftAutosaveTimer);
    draftAutosaveTimer = window.setTimeout(() => {
      autosaveDraft().catch(() => setSaveState("Autosave failed", "error"));
    }, 1800);
  }

  async function autosaveDraft() {
    if (!contentForm) return;
    syncMarkdownSource();
    const data = readContentForm(contentForm);
    if (!data.id || data.status !== "draft") return;
    if (!data.title.trim() || !data.slug.trim() || !data.description.trim() || !data.bodyMarkdown.trim()) return;
    const requestId = ++draftAutosaveRequestId;
    setSaveState("Autosaving draft...", "saving");
    const { id, ...body } = data;
    const saved = await api(`/api/admin/content/posts/${id}`, { method: "PATCH", body: JSON.stringify({ ...body, status: "draft" }) });
    if (requestId !== draftAutosaveRequestId) return;
    const index = contentPosts.findIndex((post) => post.id === saved.post.id);
    if (index >= 0) contentPosts[index] = saved.post;
    renderContentPosts();
    setSaveState("Autosaved", "saved");
  }

  function filteredPosts() {
    const query = ((document.querySelector("[data-post-search]") as HTMLInputElement | null)?.value || "").trim().toLowerCase();
    if (!query) return contentPosts;
    return contentPosts.filter((post) => [
      post.title,
      post.slug,
      post.lang,
      post.category,
      ...(post.tags || [])
    ].join(" ").toLowerCase().includes(query));
  }

  function renderContentPosts() {
    const target = document.querySelector("[data-content-admin]");
    const count = document.querySelector("[data-content-count]");
    if (count) count.textContent = String(contentPosts.length);
    if (!target) return;
    const posts = filteredPosts();
    if (!posts.length) {
      target.innerHTML = "<p class='studio-muted'>No matching posts.</p>";
      return;
    }
    target.innerHTML = posts.map((post) => `
      <article class="studio-list-item">
        <div>
          <strong>${escapeHtml(post.title || "Untitled")}</strong>
          <div class="studio-meta"><span>${escapeHtml(post.lang)}</span><span>${escapeHtml(post.slug)}</span></div>
          <div class="studio-tag-row">
            <span class="studio-tag">${escapeHtml(post.status)}</span>
            <span class="studio-tag">${escapeHtml(post.category)}</span>
            <span class="studio-tag">v${escapeHtml(post.version ?? 1)}</span>
          </div>
        </div>
        <div class="studio-list-actions">
          <button type="button" data-edit-post="${post.id}">Edit</button>
          <a class="studio-button secondary" href="${escapeHtml(publicPostHref(post))}" target="_blank" rel="noreferrer">Open</a>
          <button class="secondary danger" type="button" data-delete-post="${post.id}">Delete</button>
        </div>
      </article>
    `).join("");
  }

  async function loadContentPosts() {
    const data = await api("/api/admin/content/posts");
    contentPosts = data.posts || [];
    renderContentPosts();
    if (!contentForm || (contentForm.elements.namedItem("id") as HTMLInputElement | null)?.value) return;
    if (!getEditorMarkdown()) fillContentForm();
  }

  function renderRevisions(revisions: any[]) {
    const target = document.querySelector("[data-revisions-admin]");
    if (!target) return;
    if (!revisions.length) {
      target.innerHTML = "<p class='studio-muted'>Save the post to start revision history.</p>";

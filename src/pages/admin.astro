  document.querySelector("[data-content-form] input[name='title']")?.addEventListener("input", (event) => {
    const form = (event.currentTarget as HTMLInputElement).form;
    const slug = form?.elements.namedItem("slug") as HTMLInputElement | null;
    const id = form?.elements.namedItem("id") as HTMLInputElement | null;
    if (slug && !id?.value && !slug.dataset.touched) slug.value = slugify((event.currentTarget as HTMLInputElement).value);
    setSaveState("Unsaved changes", "dirty");
    scheduleDraftAutosave();
  });

  document.querySelector("[data-content-form] input[name='slug']")?.addEventListener("input", (event) => {
    (event.currentTarget as HTMLInputElement).dataset.touched = "true";
    setSaveState("Unsaved changes", "dirty");
    scheduleDraftAutosave();
  });

	  contentForm?.addEventListener("input", (event) => {
	    const target = event.target as HTMLElement;
	    if (!target.closest("[data-doc-editor]")) {
        setSaveState("Unsaved changes", "dirty");
        scheduleDraftAutosave();
      }
	  });

  contentForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    window.clearTimeout(draftAutosaveTimer);
    const form = event.currentTarget as HTMLFormElement;
    syncMarkdownSource();
    if (!form.reportValidity()) return;
    if (!getEditorMarkdown().trim()) {
      setSaveState("Body is required.", "error");
      return;
    }
    const submitter = (event as SubmitEvent).submitter as HTMLElement | null;
    const forcedStatus = submitter?.getAttribute("data-save-status");
    if (forcedStatus) {
      const status = form.elements.namedItem("status") as HTMLSelectElement | null;
      if (status) status.value = forcedStatus;
    }
    const data = readContentForm(form);
    const { id, ...body } = data;
    const path = id ? `/api/admin/content/posts/${id}` : "/api/admin/content/posts";
    setSaveState(data.status === "published" ? "Publishing..." : "Saving draft...", "saving");
    try {
      const saved = await api(path, { method: id ? "PATCH" : "POST", body: JSON.stringify(body) });
      fillContentForm(saved.post);
      setStatus(data.status === "published" ? "Post published." : "Draft saved.");
      setSaveState(data.status === "published" ? "Published" : "Draft saved", "saved");
      await loadContentPosts();
    } catch (error) {
      const message = error instanceof Error ? error.message : "Save failed.";
      setStatus(message);
      setSaveState(message, "error");
    }
  });

  document.querySelector("[data-asset-upload]")?.addEventListener("change", async (event) => {
    const input = event.currentTarget as HTMLInputElement;
    const file = input.files?.[0];
    if (!file) return;
    const body = new FormData();
    body.append("file", file);
    if (uploadStatus) uploadStatus.textContent = "Uploading...";
    try {
	      const data = await api("/api/admin/assets", { method: "POST", body });
	      insertEditorImage(data.asset.publicPath, file.name);
      setStatus("Image uploaded.");
      if (uploadStatus) uploadStatus.textContent = "Image inserted.";
    } catch (error) {
      const message = error instanceof Error ? error.message : "Image upload failed.";
      setStatus(message);
      if (uploadStatus) uploadStatus.textContent = message;
    } finally {
      input.value = "";
    }
  });

	  document.addEventListener("click", async (event) => {
    const button = (event.target as HTMLElement).closest("button");
    if (!button) return;

    if (button.hasAttribute("data-toggle-meta")) {
      const isOpen = adminApp?.hasAttribute("data-meta-open") ?? false;
      setWorkspaceDrawer("meta", !isOpen);
      return;
    }

    if (button.hasAttribute("data-close-meta")) {
      setWorkspaceDrawer("meta", false);
      return;
    }

    if (button.hasAttribute("data-toggle-library")) {
      const isOpen = adminApp?.hasAttribute("data-library-open") ?? false;
      setWorkspaceDrawer("library", !isOpen);
      return;
    }

    if (button.hasAttribute("data-api-retry")) {
      ownerStatusStartedAt = Date.now();
      await checkOwnerStatusWithRetry(true);
      return;
    }

    const panel = button.getAttribute("data-panel");
    if (panel) showPanel(panel);

    const refresh = button.getAttribute("data-refresh");
    if (refresh === "content") await loadContentPosts();
    if (refresh === "comments") await loadComments();
    if (refresh === "portfolio") await loadPortfolio();
    if (refresh === "profile") await loadProfile();
    if (button.hasAttribute("data-refresh-quotes")) {
      setStatus("Refreshing market quotes...");
      await api("/api/admin/market/quotes/refresh", { method: "POST", body: JSON.stringify({}) });
      await loadPortfolio();
      setStatus("Market quote refresh complete.");
    }

    const editorMode = button.getAttribute("data-editor-view");
    if (editorMode) setEditorMode(editorMode);

    const editorAction = button.getAttribute("data-doc-action");
    if (editorAction === "undo") {
      docsEditor?.undo();
      syncMarkdownSource();
      scheduleEditorPreview();
      updateEditorChrome();
    }
    if (editorAction === "redo") {
      docsEditor?.redo();
      syncMarkdownSource();
      scheduleEditorPreview();
      updateEditorChrome();
    }

    const mark = button.getAttribute("data-doc-mark");
    if (mark === "bold") docsEditor?.toggleBold();
    if (mark === "italic") docsEditor?.toggleItalic();
    if (mark === "underline") docsEditor?.toggleUnderline();
    if (mark === "code") docsEditor?.toggleCode();
    if (mark) {
      syncMarkdownSource();
      scheduleEditorPreview();
      updateEditorChrome();
    }

    const docCommand = button.getAttribute("data-doc-command");
    if (docCommand) applyDocCommand(docCommand);

    const align = button.getAttribute("data-doc-align") as "left" | "center" | "right" | "justify" | null;
    if (align) {
      docsEditor?.setTextAlign(align);
      syncMarkdownSource();
      scheduleEditorPreview();
      updateEditorChrome();
    }

    if (button.hasAttribute("data-md-link")) openLinkDialog();
    if (button.hasAttribute("data-md-emoji") && emojiPicker) {
      const rect = button.getBoundingClientRect();
      emojiPicker.style.left = `${Math.min(rect.left, window.innerWidth - 260)}px`;
      emojiPicker.style.top = `${rect.bottom + 8}px`;
      emojiPicker.hidden = !emojiPicker.hidden;
    }
    if (button.closest(".docs-menu-panel") && !button.hasAttribute("data-md-emoji")) {
      button.closest("details")?.removeAttribute("open");
    }
    const emoji = button.getAttribute("data-emoji-value");
    if (emoji) {
      replaceEditorSelection(emoji);
      if (emojiPicker) emojiPicker.hidden = true;
    }
    if (button.hasAttribute("data-link-cancel")) linkDialog?.close();

    const id = button.getAttribute("data-mod-id");
    const kind = button.getAttribute("data-mod-kind") as "comments" | null;
    const modStatus = button.getAttribute("data-mod-status");
    if (id && kind && modStatus) await moderate(Number(id), modStatus);

    const selectedAsset = button.getAttribute("data-select-asset");
    if (button.hasAttribute("data-select-asset")) {
      const form = document.querySelector("[data-position-form]") as HTMLFormElement | null;
      const setField = (name: string, value: string) => {
        const field = form?.elements.namedItem(name) as HTMLInputElement | HTMLSelectElement | null;
        if (field) field.value = value;
      };
      setField("assetId", selectedAsset || "");
      setField("provider", button.getAttribute("data-asset-provider") || "manual");
      setField("exchange", button.getAttribute("data-asset-exchange") || "");
      setField("ticker", button.getAttribute("data-asset-symbol") || "");
      setField("name", button.getAttribute("data-asset-name") || "");
      setField("assetClass", button.getAttribute("data-asset-type") || "Equity");
      setField("region", button.getAttribute("data-asset-region") || "");
      setField("currency", button.getAttribute("data-asset-currency") || "USD");
      setField("aliases", button.getAttribute("data-asset-aliases") || "");
      renderMarketResults([]);
      setStatus("Asset selected.");
    }

    const deletePosition = button.getAttribute("data-delete-position");
    if (deletePosition) {
      await api(`/api/admin/portfolio/positions/${deletePosition}`, { method: "DELETE" });
      await loadPortfolio();
      fillPositionForm();
    }
    const savePositionRow = button.getAttribute("data-save-position-row");
    if (savePositionRow) {
      const position = portfolioPositions.find((item) => item.id === Number(savePositionRow));
      const row = button.closest("[data-position-row]") as HTMLElement | null;
      if (position && row) {
        const inlineValue = (name: string) => {
          const field = row.querySelector(`[data-inline-field="${name}"]`) as HTMLInputElement | HTMLSelectElement | null;
          return field?.value ?? "";
        };
        const quantity = Number(inlineValue("quantity"));
        const costPrice = Number(inlineValue("costPrice"));
        const body = {
          assetId: position.assetId ?? undefined,
          provider: "alpha_vantage",
          exchange: position.exchange ?? "",
          aliases: position.aliases ?? [],
          ticker: inlineValue("ticker"),
          name: inlineValue("name"),
          assetClass: inlineValue("assetClass"),
          region: inlineValue("region"),
          currency: position.currency || position.quote?.currency || "USD",
          quantity,
          costBasisCents: costBasisCentsFromInputs(quantity, costPrice),
          marketValueCents: position.marketValueCents ?? 0,
          asOf: position.asOf || todayDateInputValue(),
          status: inlineValue("status") || position.status || "active",
          notes: position.notes ?? ""
        };
        setStatus("Saving position row...");
        await api(`/api/admin/portfolio/positions/${savePositionRow}`, { method: "PATCH", body: JSON.stringify(body) });
        await loadPortfolio();
        setStatus("Position row saved.");
      }
    }
    const editPosition = button.getAttribute("data-edit-position");
    if (editPosition) {
      const position = portfolioPositions.find((item) => item.id === Number(editPosition));
      fillPositionForm(position);
    }

    const editPost = button.getAttribute("data-edit-post");
    if (editPost) {
      const post = contentPosts.find((item) => item.id === Number(editPost));
      fillContentForm(post);
      showPanel("content");
      setWorkspaceDrawer("library", false);
    }
    const revision = button.getAttribute("data-restore-revision");
    const revisionPost = button.getAttribute("data-restore-post");
    if (revision && revisionPost && window.confirm("Restore this revision?")) {
      const saved = await api(`/api/admin/content/posts/${revisionPost}/revisions/${revision}/restore`, { method: "POST" });
      fillContentForm(saved.post);
      setStatus("Revision restored.");
      await loadContentPosts();
    }
    const deletePost = button.getAttribute("data-delete-post");
    if (deletePost && window.confirm("Delete this post?")) {
      await api(`/api/admin/content/posts/${deletePost}`, { method: "DELETE" });
      await loadContentPosts();
      fillContentForm();
    }
    if (button.hasAttribute("data-new-post")) {
      fillContentForm();
      setWorkspaceDrawer("meta", true);
      setWorkspaceDrawer("library", false);
    }
    if (button.hasAttribute("data-position-cancel")) fillPositionForm();
    if (button.hasAttribute("data-logout")) {
      await api("/api/admin/logout", { method: "POST" });
      location.reload();
    }
  });

  linkDialogForm?.addEventListener("submit", (event) => {
    event.preventDefault();
    const textInput = linkDialogForm.elements.namedItem("text") as HTMLInputElement | null;
    const urlInput = linkDialogForm.elements.namedItem("url") as HTMLInputElement | null;
	    const text = textInput?.value.trim() || "link text";
	    const url = urlInput?.value.trim() || "";
	    if (!url) return;
	    setupEditor();
	    docsEditor?.setLink(url, text);

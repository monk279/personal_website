    }
    target.innerHTML = revisions.map((revision) => `
      <article class="studio-list-item compact">
        <div>
          <strong>v${escapeHtml(revision.version)}</strong>
          <div class="studio-meta"><span>${escapeHtml(revision.changedAt)}</span><span>${escapeHtml(revision.status)}</span></div>
        </div>
        <button class="secondary" type="button" data-restore-revision="${revision.id}" data-restore-post="${revision.postId}">Restore</button>
      </article>
    `).join("");

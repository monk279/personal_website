  function setLoggedOut(message = "Log in to manage the site.") {
    setAdminState("login");
    setWorkspaceDrawer("meta", false);
    setWorkspaceDrawer("library", false);
    setStatus(message);
  }

  function showPanel(name: string) {
    adminApp?.setAttribute("data-active-panel", name);
    if (name !== "content") {
      setWorkspaceDrawer("meta", false);
      setWorkspaceDrawer("library", false);
    }
    for (const panel of document.querySelectorAll("[data-admin-panel]")) {
      (panel as HTMLElement).hidden = panel.getAttribute("data-admin-panel") !== name;
    }
    for (const button of document.querySelectorAll("[data-panel]")) {
      button.classList.toggle("active", button.getAttribute("data-panel") === name);

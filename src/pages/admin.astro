---
import AdminLayout from "@/layouts/AdminLayout.astro";
---

<AdminLayout title="Owner Studio" description="Owner management dashboard for zhaohe.me.">
  <div class="studio-app docs-admin-app" data-admin-app data-admin-state="booting">
    <section class="studio-login-screen" data-login-screen>
      <div class="studio-login-card">
        <div>
          <p class="studio-kicker">Private management</p>
          <h1>Owner Studio</h1>
          <p class="studio-muted">Sign in to write posts, moderate comments, update market-priced portfolio data, and edit profile text.</p>
        </div>

        <div class="owner-diagnostics" aria-live="polite">
          <p><span class="status-dot" data-api-dot></span><span data-api-status>Checking API...</span></p>
          <p><span class="status-dot" data-owner-dot></span><span data-owner-status>Checking owner account...</span></p>
        </div>

        <div class="admin-runtime-note">
          <strong>Editing requires the API and database.</strong>
          <p>Static preview can show the public site, but posts and portfolio management need the local runtime.</p>
          <code>bun run dev</code>
          <span>Then open http://127.0.0.1:4321/admin.</span>
          <button class="secondary" type="button" data-api-retry hidden>Retry now</button>
        </div>

        <form class="studio-login-form" data-login-form>
          <label>Email<input name="email" type="email" autocomplete="username" required /></label>
          <label>Password<input name="password" type="password" autocomplete="current-password" required /></label>
          <p class="local-login-hint" data-owner-hint hidden>
            Local dev owner: <strong data-owner-email></strong><br />
            Password: <strong data-owner-password></strong>
          </p>
          <button type="submit">Log in</button>
          <p class="studio-status" data-admin-status>Log in to manage the site.</p>
        </form>
      </div>
    </section>

    <section class="studio-shell docs-workspace-shell" data-studio-shell hidden>
      <header class="studio-topbar">
        <div>
          <p class="studio-kicker">zhaohe.me</p>
          <h1>Owner Studio</h1>
        </div>
        <div class="studio-topbar-actions">
          <p class="studio-status" data-admin-status></p>
          <p class="owner-pill" data-admin-name></p>
          <a class="studio-button secondary" href="/" target="_blank" rel="noreferrer">Public site</a>
          <button class="secondary" type="button" data-logout>Log out</button>
        </div>
      </header>

      <div class="studio-grid">
        <aside class="studio-sidebar">
          <nav class="studio-nav" aria-label="Owner Studio navigation">
            <button class="active" type="button" data-panel="content">Posts</button>
            <button type="button" data-panel="comments">Comments <span data-pending-comments>0</span></button>
            <button type="button" data-panel="portfolio">Portfolio</button>
            <button type="button" data-panel="profile">Profile</button>
          </nav>
          <div class="studio-sidebar-note">
            <strong>Reader accounts stay off.</strong>
            <span>Comments go through spam checks and moderation before appearing publicly.</span>
          </div>
        </aside>

        <main class="studio-main" data-admin-workspace>
          <section class="studio-panel posts-panel" data-admin-panel="content">
            <div class="studio-panel-heading">
              <div>
                <p class="studio-kicker">Document editor</p>
                <h2>Posts</h2>
                <p class="studio-muted">Write in a document canvas. Metadata and revisions live in Details.</p>
              </div>
              <div class="studio-actions doc-primary-actions">
                <button class="secondary" type="button" data-toggle-library>Library</button>
                <button type="button" data-new-post>New post</button>
                <button class="secondary" type="submit" form="post-editor-form" data-save-status="draft">Save draft</button>
                <button type="submit" form="post-editor-form" data-save-status="published">Publish</button>
                <button class="secondary" type="button" data-toggle-meta>Details</button>
                <button class="secondary" type="button" data-refresh="content">Refresh</button>
              </div>
            </div>

            <div class="posts-workspace">
              <aside class="post-library" data-post-library>
                <div class="post-library-heading">
                  <h3>All posts</h3>
                  <button class="secondary post-library-close" type="button" data-toggle-library>Close</button>
                  <span class="studio-tag" data-content-count>0</span>
                </div>
                <label class="compact-field">Search
                  <input data-post-search placeholder="Title, slug, tag" />
                </label>
                <div class="post-list" data-content-admin></div>
              </aside>

              <form id="post-editor-form" class="post-editor-grid" data-content-form>
                <input name="id" type="hidden" />
                <textarea name="bodyMarkdown" data-markdown-source hidden></textarea>

                <section class="post-writing-surface">
                  <div class="document-status-row">
                    <span class="studio-tag" data-editor-status>draft</span>
                    <span class="editor-save-indicator" data-editor-save-state>Ready</span>
                  </div>
                  <div class="post-title-row">
                    <input class="post-title-input" name="title" placeholder="Untitled post" maxlength="160" required />
                  </div>
                  <textarea class="post-description-input" name="description" maxlength="300" placeholder="Short description for listings and search." required></textarea>

                  <div class="docs-editor-chrome" data-doc-toolbar>
                    <div class="editor-command-bar docs-command-bar" aria-label="Document toolbar">
                      <div class="toolbar-group history-tools" aria-label="History">
                        <button class="secondary compact-tool" type="button" data-doc-action="undo" title="Undo">Undo</button>
                        <button class="secondary compact-tool" type="button" data-doc-action="redo" title="Redo">Redo</button>
                      </div>

                      <label class="toolbar-select-label">Style
                        <select data-doc-block-style aria-label="Text style">
                          <option value="paragraph">Paragraph</option>
                          <option value="h1">Heading 1</option>
                          <option value="h2">Heading 2</option>
                          <option value="h3">Heading 3</option>
                          <option value="quote">Quote</option>
                          <option value="code">Code block</option>
                        </select>
                      </label>

                      <div class="toolbar-group" aria-label="Inline formatting">
                        <button class="secondary mark-tool" type="button" data-doc-mark="bold" title="Bold">B</button>
                        <button class="secondary mark-tool italic" type="button" data-doc-mark="italic" title="Italic">I</button>
                        <button class="secondary mark-tool underline" type="button" data-doc-mark="underline" title="Underline">U</button>
                        <button class="secondary mark-tool strike" type="button" data-doc-command="strike" title="Strikethrough">S</button>
                        <button class="secondary mark-tool code" type="button" data-doc-mark="code" title="Inline code">Code</button>
                        <button class="secondary mark-tool" type="button" data-doc-command="highlight" title="Highlight">Mark</button>
                      </div>

                      <div class="toolbar-group" aria-label="Lists and alignment">
                        <button class="secondary compact-tool" type="button" data-doc-command="ul" title="Bullet list">Bullets</button>
                        <button class="secondary compact-tool" type="button" data-doc-command="ol" title="Numbered list">Numbers</button>
                        <button class="secondary compact-tool" type="button" data-doc-command="task" title="Task list">Tasks</button>
                        <button class="secondary compact-tool" type="button" data-doc-align="left" title="Align left">Left</button>
                        <button class="secondary compact-tool" type="button" data-doc-align="center" title="Align center">Center</button>
                        <button class="secondary compact-tool" type="button" data-doc-align="right" title="Align right">Right</button>
                      </div>

                      <details class="docs-menu">
                        <summary>Insert</summary>
                        <div class="docs-menu-panel">
                          <button type="button" data-md-link>Link</button>
                          <button type="button" data-doc-command="hr">Divider</button>
                          <button type="button" data-doc-command="table">Table</button>
                          <button type="button" data-md-emoji>Emoji</button>
                          <button type="button" data-doc-command="clear">Clear formatting</button>
                          <label class="menu-upload">Image
                            <input name="asset" type="file" accept="image/png,image/jpeg,image/gif,image/webp" data-asset-upload />
                          </label>
                        </div>
                      </details>

                      <div class="toolbar-spacer"></div>
                      <div class="docs-editor-stats" aria-live="polite">
                        <span data-editor-word-count>0 words</span>
                        <span data-editor-character-count>0 chars</span>
                      </div>
                      <span class="editor-upload-status" data-upload-status></span>
                    </div>

                    <div class="editor-mode-bar docs-mode-bar">
                    <div class="segmented-control" role="group" aria-label="Editor view">
                      <button class="active" type="button" data-editor-view="edit">Edit</button>
                      <button type="button" data-editor-view="split">Split</button>
                      <button type="button" data-editor-view="preview">Preview</button>
                    </div>
                    <button class="secondary" type="button" data-toggle-meta>Details</button>
                    </div>
                  </div>

	                  <div class="editor-stage" data-editor-stage data-mode="edit">
                    <div class="bubble-toolbar" data-bubble-toolbar hidden>
                      <button type="button" data-doc-mark="bold">Bold</button>
                      <button type="button" data-doc-mark="italic">Italic</button>
                      <button type="button" data-doc-mark="underline">Underline</button>
                      <button type="button" data-doc-mark="code">Code</button>
                      <button type="button" data-md-link>Link</button>
                    </div>
	                    <div class="editor-pane" data-editor-edit-pane>
	                      <div class="doc-editor-host" data-doc-editor role="textbox" aria-multiline="true"></div>
	                    </div>
                    <section class="editor-preview" data-editor-preview-pane aria-label="Post preview">
                      <div class="prose" data-editor-preview><p class="studio-muted">Preview appears here.</p></div>
                    </section>
                  </div>
                </section>

                <aside class="publish-sidebar" data-meta-drawer aria-label="Post details">
                  <div class="publish-card primary">
                    <div>
                      <p class="studio-kicker">Post details</p>
                      <h3 data-editor-title>New post</h3>
                    </div>
                    <div class="publish-actions">
                      <button class="secondary" type="button" data-close-meta>Close</button>
                      <button type="submit" data-save-status="draft">Save draft</button>
                      <button type="submit" data-save-status="published">Publish</button>
                      <a class="studio-button secondary" data-content-open href="/blog" target="_blank" rel="noreferrer">Open public page</a>
                    </div>
                  </div>

                  <div class="publish-card">
                    <h3>Metadata</h3>
                    <div class="compact-form">
                      <label>Slug<input name="slug" required maxlength="120" pattern="[a-z0-9]+(-[a-z0-9]+)*" /></label>
                      <label>Language
                        <select name="lang">
                          <option value="en">English</option>
                          <option value="zh">Chinese</option>
                        </select>
                      </label>
                      <label>Status
                        <select name="status">
                          <option value="draft">draft</option>
                          <option value="published">published</option>
                          <option value="archived">archived</option>
                        </select>
                      </label>
                      <label>Category<input name="category" value="Notes" required maxlength="80" /></label>
                      <label>Tags<input name="tags" placeholder="writing, investing, notes" /></label>
                      <label>Published at<input name="publishedAt" type="datetime-local" /></label>
                    </div>
                  </div>

                  <div class="publish-card revision-panel">
                    <div class="post-library-heading">
                      <h3>Revision history</h3>
                      <span class="studio-tag" data-current-version>v1</span>
                    </div>
                    <div class="post-list" data-revisions-admin><p class="studio-muted">Save the post to start revision history.</p></div>
                  </div>
                </aside>
              </form>
            </div>
          </section>

          <section class="studio-panel" data-admin-panel="comments" hidden>
            <div class="studio-panel-heading">
              <div>
                <p class="studio-kicker">Inbox</p>
                <h2>Comments</h2>
              </div>
              <button class="secondary" type="button" data-refresh="comments">Refresh</button>
            </div>
            <div data-comments-admin></div>
          </section>

          <section class="studio-panel" data-admin-panel="portfolio" hidden>
            <div class="studio-panel-heading">
              <div>
                <p class="studio-kicker">Investment sheet</p>
                <h2>Portfolio</h2>
                <p class="studio-muted">Edit holdings in the sheet or use the add/edit drawer below.</p>
              </div>
              <div class="studio-actions">
                <button class="secondary" type="button" data-refresh="portfolio">Refresh</button>
                <button type="button" data-refresh-quotes>Refresh quotes</button>
              </div>
            </div>
            <form class="studio-form-grid portfolio-edit-drawer" data-position-form>
              <input name="id" type="hidden" />
              <input name="assetId" type="hidden" />
              <input name="provider" type="hidden" value="alpha_vantage" />
              <input name="exchange" type="hidden" />
              <input name="asOf" type="hidden" />
              <input name="costBasisCents" type="hidden" />
              <label>Search stocks or ETFs / 搜索股票或 ETF
                <input data-market-search role="combobox" aria-controls="market-search-results" aria-expanded="false" placeholder="VT, Apple, 苹果, 全球股票..." autocomplete="off" />
              </label>
              <p class="studio-status" data-market-status>Search provider and cached assets are ready.</p>
              <div class="post-list market-search-results" id="market-search-results" data-market-results hidden></div>
              <div class="studio-grid-two">
                <label>Ticker<input name="ticker" required /></label>
                <label>Name<input name="name" required /></label>
                <label>Asset class<input name="assetClass" required /></label>
                <label>Region<input name="region" required /></label>
                <label>Currency<input name="currency" value="USD" required /></label>
                <label>Aliases / 中文别名<input name="aliases" placeholder="Apple, 苹果, AAPL" /></label>
                <label>Quantity<input name="quantity" type="number" min="0" step="0.0001" required /></label>
                <label>Average cost price
                  <input name="costPrice" type="number" min="0" step="0.0001" inputmode="decimal" required />
                  <span class="field-help">Your average buy price per share/unit. Total cost and P/L are calculated from this.</span>
                </label>
                <label>Status
                  <select name="status">
                    <option value="active">active</option>
                    <option value="watchlist">watchlist</option>
                    <option value="closed">closed</option>
                  </select>
                </label>
              </div>
              <p class="portfolio-derived-note" data-cost-basis-preview>Total cost basis will be calculated from quantity and average cost price.</p>
              <label>Notes<textarea name="notes"></textarea></label>
              <div class="studio-actions">
                <button type="submit" data-position-submit>Add position</button>
                <button class="secondary" type="button" data-position-cancel hidden>Cancel edit</button>
              </div>
            </form>
            <section class="portfolio-sheet" data-portfolio-admin></section>
          </section>

          <section class="studio-panel" data-admin-panel="profile" hidden>
            <div class="studio-panel-heading">
              <div>
                <p class="studio-kicker">Settings document</p>
                <h2>Profile</h2>
              </div>
              <button class="secondary" type="button" data-refresh="profile">Refresh</button>
            </div>
            <form class="studio-form-grid" data-profile-form>
              <label>Display name<input name="displayName" required /></label>
              <label>Headline<input name="headline" required /></label>
              <label>English bio<textarea name="bioEn" required></textarea></label>
              <label>Chinese bio<textarea name="bioZh" required></textarea></label>
              <div class="studio-grid-two">
                <label>Location<input name="location" /></label>
                <label>Email<input name="email" type="email" /></label>
              </div>
              <button type="submit">Save profile</button>
            </form>
          </section>
        </main>
      </div>
    </section>

    <dialog class="studio-dialog" data-link-dialog>
      <form method="dialog" data-link-dialog-form>
        <h2>Insert link</h2>
        <label>Text<input name="text" required /></label>
        <label>URL<input name="url" type="url" placeholder="https://example.com" required /></label>
        <div class="studio-actions">
          <button type="submit">Insert</button>
          <button class="secondary" value="cancel" type="button" data-link-cancel>Cancel</button>
        </div>
      </form>
    </dialog>

    <div class="emoji-popover" data-emoji-picker hidden>
      {["😀", "✨", "📌", "💡", "📈", "✅", "🔥", "🙏", "🧠", "📝", "🚀", "❤️"].map((emoji) => (
        <button type="button" data-emoji-value={emoji}>{emoji}</button>
      ))}
    </div>
  </div>
</AdminLayout>

<script>
  import { createDocsEditor, type DocsEditorFormatState, type DocsEditorHandle } from "@/scripts/admin/editor";

  const adminApp = document.querySelector("[data-admin-app]") as HTMLElement | null;
  const statusEls = document.querySelectorAll("[data-admin-status]");
  const apiStatus = document.querySelector("[data-api-status]");
  const ownerStatus = document.querySelector("[data-owner-status]");
  const apiDot = document.querySelector("[data-api-dot]");
  const ownerDot = document.querySelector("[data-owner-dot]");
  const ownerHint = document.querySelector("[data-owner-hint]") as HTMLElement | null;
  const ownerEmailHint = document.querySelector("[data-owner-email]");
  const ownerPasswordHint = document.querySelector("[data-owner-password]");
  const loginScreen = document.querySelector("[data-login-screen]") as HTMLElement | null;
  const loginForm = document.querySelector("[data-login-form]") as HTMLFormElement | null;
  const apiRetryButton = document.querySelector("[data-api-retry]") as HTMLButtonElement | null;
  const studioShell = document.querySelector("[data-studio-shell]") as HTMLElement | null;
  const adminName = document.querySelector("[data-admin-name]");
  const contentForm = document.querySelector("[data-content-form]") as HTMLFormElement | null;
  const markdownSource = document.querySelector("[data-markdown-source]") as HTMLTextAreaElement | null;
  const editorHost = document.querySelector("[data-doc-editor]") as HTMLElement | null;
  const editorStage = document.querySelector("[data-editor-stage]") as HTMLElement | null;
  const editorPreview = document.querySelector("[data-editor-preview]") as HTMLElement | null;
  const editorSaveState = document.querySelector("[data-editor-save-state]") as HTMLElement | null;
  const editorBubbleToolbar = document.querySelector("[data-bubble-toolbar]") as HTMLElement | null;
  const editorBlockStyle = document.querySelector("[data-doc-block-style]") as HTMLSelectElement | null;
  const editorWordCount = document.querySelector("[data-editor-word-count]") as HTMLElement | null;
  const editorCharacterCount = document.querySelector("[data-editor-character-count]") as HTMLElement | null;
  const emojiPicker = document.querySelector("[data-emoji-picker]") as HTMLElement | null;
  const linkDialog = document.querySelector("[data-link-dialog]") as HTMLDialogElement | null;
  const linkDialogForm = document.querySelector("[data-link-dialog-form]") as HTMLFormElement | null;
  const uploadStatus = document.querySelector("[data-upload-status]") as HTMLElement | null;
  const marketStatus = document.querySelector("[data-market-status]") as HTMLElement | null;
  const marketSearchInput = document.querySelector("[data-market-search]") as HTMLInputElement | null;
  let csrfToken = "";
  let contentPosts: any[] = [];
  let portfolioPositions: any[] = [];
  let suppressEditorDirty = false;
  let previewTimer: number | undefined;
  let previewRequestId = 0;
  let marketSearchTimer: number | undefined;
  let draftAutosaveTimer: number | undefined;
  let draftAutosaveRequestId = 0;
  let docsEditor: DocsEditorHandle | null = null;
  let ownerStatusRetryTimer: number | undefined;
  let ownerStatusStartedAt = 0;
  let ownerStatusRequestId = 0;
  let retryMeAfterApiOnline = false;

  class AdminApiError extends Error {
    status: number;
    code: string;

    constructor(message: string, status = 0, code = "API_ERROR") {
      super(message);
      this.status = status;
      this.code = code;
    }
  }

  const backendUnavailableMessage = "API backend is not running. Run bun run dev, then open http://127.0.0.1:4321/admin.";
  const apiCheckingMessage = "Checking local API...";
  const directLocalApiOrigin = ["127.0.0.1", "localhost"].includes(window.location.hostname)
    ? "http://127.0.0.1:3000"
    : "";

  type AdminState = "booting" | "offline" | "login" | "workspace";

  function setAdminState(state: AdminState) {
    adminApp?.setAttribute("data-admin-state", state);
    if (loginScreen) loginScreen.hidden = state === "workspace";
    if (studioShell) studioShell.hidden = state !== "workspace";
  }

  function isWorkspaceState() {
    return adminApp?.getAttribute("data-admin-state") === "workspace";
  }

  function setWorkspaceDrawer(name: "meta" | "library", open: boolean) {
    const attr = name === "meta" ? "data-meta-open" : "data-library-open";
    adminApp?.toggleAttribute(attr, open);
    if (name === "meta") {
      const drawer = document.querySelector("[data-meta-drawer]") as HTMLElement | null;
      drawer?.style.setProperty("transform", "none", "important");
      if (open) drawer?.style.setProperty("right", "0", "important");
      else drawer?.style.removeProperty("right");
    }
  }

  const escapeHtml = (value: unknown) => String(value ?? "")
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#039;");

  const setStatus = (message: string) => {
    for (const statusEl of statusEls) statusEl.textContent = message;
  };

  function setLoginDisabled(disabled: boolean) {
    if (!loginForm) return;
    loginScreen?.toggleAttribute("data-api-offline", disabled);
    if (!isWorkspaceState()) setAdminState(disabled ? "offline" : "login");
    loginForm.hidden = disabled;
    if (apiRetryButton) {
      apiRetryButton.hidden = !disabled;
      apiRetryButton.disabled = false;
    }
    loginForm.toggleAttribute("data-disabled", disabled);
    loginForm.setAttribute("aria-disabled", String(disabled));
    for (const element of Array.from(loginForm.elements)) {
      if (element instanceof HTMLInputElement || element instanceof HTMLButtonElement) element.disabled = disabled;
    }
  }

  function setSaveState(message: string, state = "idle") {
    if (!editorSaveState) return;
    editorSaveState.textContent = message;
    editorSaveState.setAttribute("data-state", state);
  }

  function setButtonState(selector: string, active: boolean, disabled = false) {
    for (const button of document.querySelectorAll(selector)) {
      button.classList.toggle("active", active);
      if (button instanceof HTMLButtonElement) button.disabled = disabled;
    }
  }

  function hideEditorBubble() {
    if (!editorBubbleToolbar) return;
    editorBubbleToolbar.hidden = true;
  }

  function updateEditorBubble(state: DocsEditorFormatState) {
    if (!editorBubbleToolbar || !editorHost || !state.selectionText) {
      hideEditorBubble();
      return;
    }
    const selection = window.getSelection();
    if (!selection || selection.rangeCount === 0 || selection.isCollapsed || !editorHost.contains(selection.anchorNode)) {
      hideEditorBubble();
      return;
    }
    const rect = selection.getRangeAt(0).getBoundingClientRect();
    if (!rect.width && !rect.height) {
      hideEditorBubble();
      return;
    }
    const toolbarWidth = editorBubbleToolbar.offsetWidth || 320;
    editorBubbleToolbar.style.left = `${Math.max(12, Math.min(rect.left + rect.width / 2 - toolbarWidth / 2, window.innerWidth - toolbarWidth - 12))}px`;
    editorBubbleToolbar.style.top = `${Math.max(72, rect.top - 48)}px`;
    editorBubbleToolbar.hidden = false;
  }

  function updateEditorChrome(state = docsEditor?.getFormatState()) {
    if (!state) return;
    if (editorBlockStyle && editorBlockStyle.value !== state.block) editorBlockStyle.value = state.block;
    if (editorWordCount) editorWordCount.textContent = `${state.words} ${state.words === 1 ? "word" : "words"}`;
    if (editorCharacterCount) editorCharacterCount.textContent = `${state.characters} chars`;
    setButtonState("[data-doc-action='undo']", false, !state.canUndo);
    setButtonState("[data-doc-action='redo']", false, !state.canRedo);
    setButtonState("[data-doc-mark='bold']", state.bold);
    setButtonState("[data-doc-mark='italic']", state.italic);
    setButtonState("[data-doc-mark='underline']", state.underline);
    setButtonState("[data-doc-mark='code']", state.code);
    setButtonState("[data-doc-command='strike']", state.strike);
    setButtonState("[data-doc-command='highlight']", state.highlight);
    setButtonState("[data-doc-command='ul']", state.bulletList);
    setButtonState("[data-doc-command='ol']", state.orderedList);
    setButtonState("[data-doc-command='task']", state.taskList);
    setButtonState("[data-doc-command='quote']", state.blockquote);
    setButtonState("[data-doc-command='code']", state.codeBlock);
    for (const button of document.querySelectorAll("[data-doc-align]")) {
      button.classList.toggle("active", button.getAttribute("data-doc-align") === state.align);
    }
    updateEditorBubble(state);
  }

  function directLocalApiUrl(path: string) {
    return directLocalApiOrigin && path.startsWith("/api/") ? `${directLocalApiOrigin}${path}` : "";
  }

  function canRetryDirectly(error: AdminApiError, path: string) {
    return Boolean(directLocalApiUrl(path)) && error.code === "API_UNAVAILABLE";
  }

  async function requestApi(path: string, options: RequestInit = {}, direct = false) {
    const headers = new Headers(options.headers || {});
    if (options.body && !(options.body instanceof FormData) && !headers.has("content-type")) headers.set("content-type", "application/json");
    if (csrfToken && options.method && options.method !== "GET") headers.set("x-csrf-token", csrfToken);
    let response: Response;
    const url = direct ? directLocalApiUrl(path) : path;
    try {
      response = await fetch(url, { ...options, credentials: "include", headers });
    } catch {
      throw new AdminApiError("API is unavailable. Check that the local API server is running.", 0, "API_UNAVAILABLE");
    }
    const text = await response.text();
    const contentType = response.headers.get("content-type") || "";
    let data: any = {};
    try {
      data = text ? JSON.parse(text) : {};
    } catch {
      if (contentType.includes("text/html") || text.trimStart().startsWith("<!DOCTYPE") || text.trimStart().startsWith("<html")) {
        throw new AdminApiError(backendUnavailableMessage, response.status, "API_UNAVAILABLE");
      }
      data = { error: response.statusText || backendUnavailableMessage };
    }
    if (!response.ok) throw new AdminApiError(data.error || response.statusText, response.status, data.code || "API_ERROR");
    return data;
  }

  async function api(path: string, options: RequestInit = {}) {
    try {
      return await requestApi(path, options);
    } catch (error) {
      if (error instanceof AdminApiError && canRetryDirectly(error, path)) return requestApi(path, options, true);
      throw error;
    }
  }

  function setDot(target: Element | null, state: "ok" | "warn" | "bad") {
    target?.setAttribute("data-state", state);
  }

  function shouldShowOfflineDetails(manual = false) {
    return manual || Date.now() - ownerStatusStartedAt >= 15_000;
  }

  async function loadOwnerStatus(showOfflineDetails = false) {
    const requestId = ++ownerStatusRequestId;
    try {
      const data = await api("/api/admin/owner-status");
      if (requestId !== ownerStatusRequestId) return false;
      window.clearTimeout(ownerStatusRetryTimer);
      setLoginDisabled(false);
      if (apiStatus) apiStatus.textContent = "API online";
      setDot(apiDot, "ok");
      if (ownerStatus) ownerStatus.textContent = data.message || "Owner account checked.";
      setDot(ownerDot, data.hasOwner ? "ok" : "warn");
      const emailInput = loginForm?.elements.namedItem("email") as HTMLInputElement | null;
      if (data.local && data.email && data.passwordHint) {
        if (ownerEmailHint) ownerEmailHint.textContent = data.email;
        if (ownerPasswordHint) ownerPasswordHint.textContent = data.passwordHint;
        if (ownerHint) ownerHint.hidden = false;
      if (emailInput && !emailInput.value) emailInput.value = data.email;
      } else if (ownerHint) {
        ownerHint.hidden = true;
      }
      return true;
    } catch (error) {
      if (requestId !== ownerStatusRequestId) return false;
      setLoginDisabled(true);
      if (apiStatus) apiStatus.textContent = showOfflineDetails && error instanceof Error ? error.message : apiCheckingMessage;
      if (ownerStatus) ownerStatus.textContent = showOfflineDetails ? "Retrying automatically." : "Waiting for the local API proxy.";
      setDot(apiDot, "bad");
      setDot(ownerDot, "bad");
      if (ownerHint) ownerHint.hidden = true;
      return false;
    }
  }

  function scheduleOwnerStatusRetry() {
    window.clearTimeout(ownerStatusRetryTimer);
    const elapsed = Date.now() - ownerStatusStartedAt;
    const delay = elapsed < 15_000 ? 1_000 : 5_000;
    ownerStatusRetryTimer = window.setTimeout(() => {
      checkOwnerStatusWithRetry();
    }, delay);
  }

  async function checkOwnerStatusWithRetry(manual = false) {
    if (apiRetryButton) apiRetryButton.disabled = true;
    if (apiStatus) apiStatus.textContent = manual ? "Retrying local API..." : apiCheckingMessage;
    setDot(apiDot, "warn");
    const ok = await loadOwnerStatus(shouldShowOfflineDetails(manual));
    if (ok && retryMeAfterApiOnline) {
      retryMeAfterApiOnline = false;
      await loadMe();
    }
    if (!ok) {
      if (apiRetryButton) apiRetryButton.disabled = false;
      scheduleOwnerStatusRetry();
    }
  }

  function startOwnerStatusChecks() {
    ownerStatusStartedAt = Date.now();
    checkOwnerStatusWithRetry();
  }

  function updatePendingBadges(pending?: { comments?: number }) {
    const comments = document.querySelector("[data-pending-comments]");
    if (comments) comments.textContent = String(pending?.comments ?? 0);
  }

  async function refreshPendingBadges() {
    const data = await api("/api/admin/me");
    updatePendingBadges(data.pending);
  }

  function setLoggedIn(admin: any) {
    setAdminState("workspace");
    setWorkspaceDrawer("meta", false);
    setWorkspaceDrawer("library", false);
    if (adminName) adminName.textContent = `${admin.name} <${admin.email}>`;
    showPanel("content");
    setupEditor();

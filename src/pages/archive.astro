---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Archive" description="Archive moved into Blogs." locale="en" path="/archive">
  <section class="container section alias-page">
    <p class="eyebrow">Moved</p>
    <h1>Archive is now part of Blogs.</h1>
    <p class="lead">The chronological archive, tags, and search now live together on the Blogs page.</p>
    <a class="button" href="/blog?view=archive">Open Blogs archive</a>
  </section>
</BaseLayout>

---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BlogCard from "@/components/BlogCard.astro";
import { getPostsByTag, getTags } from "@/lib/posts";

export function getStaticPaths() {
  return getTags("zh").map((tag) => ({ params: { tag }, props: { tag } }));
}

const { tag } = Astro.props;
const posts = getPostsByTag("zh", tag);
---

<BaseLayout title={`标签：${tag}`} description={`${tag} 标签下的文章。`} locale="zh" path={`/zh/tags/${tag}`}>
  <section class="container section">
    <p class="eyebrow">标签</p>
    <h1 style="font-size:clamp(2.4rem,7vw,5.4rem)">{tag}</h1>
    <div class="grid two" style="margin-top:1.5rem">
      {posts.map((post) => <BlogCard post={post} locale="zh" />)}
    </div>
  </section>
</BaseLayout>
